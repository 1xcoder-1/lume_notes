{
  "name": "web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "prisma generate --schema=./prisma/schema.prisma && next build",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma migrate deploy",
    "db:reset": "prisma migrate reset --force",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "prisma migrate deploy && tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "dev": "next dev",
    "postinstall": "prisma generate --schema=./prisma/schema.prisma || echo 'Prisma generate failed, will try during build'",
    "lint": "eslint . --quiet",
    "lint:fix": "eslint . --fix",
    "start": "next start",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit"
  },
