{
  "extends": "../../packages/typescript-config/nextjs.json",
  "compilerOptions": {
    "baseUrl": "",
    "paths": {
      "@/*": ["*"],
      "@workspace/ui/*": ["../../packages/ui/src/*"]
    },
    "types": [
      "node",
      "react",
      "react-dom",
      "jest",
      "bcryptjs",
      "cors",
      "jsonwebtoken",
      "supertest"
    ],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "skipLibCheck": true
  },
  "include": [
    "next-env.d.ts",
    "next.config.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
